generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  email    String  @unique
  name     String?
  password String

  @@map("users")
}

model Contract {
  id             Int             @id @default(autoincrement())
  name           String
  employeeGroups EmployeeGroup[]
  Shift          Shift?

  @@map("contracts")
}

model EmployeeGroup {
  id         Int        @id @default(autoincrement())
  externalId Int
  name       String
  employees  Employee[]
  contractId Int
  contract   Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("employee_groups")
}

model Employee {
  id              Int           @id
  fullname        String
  employeeGroupId Int
  employeeGroup   EmployeeGroup @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade)

  @@map("employees")
}

model Shift {
  id         Int         @id @default(autoincrement())
  duration   Int
  name       String
  startDate  DateTime
  startTime  DateTime
  type       ShiftType
  customDays CustomDay[]
  contractId Int         @unique
  contract   Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

model CustomDay {
  id         Int         @id @default(autoincrement())
  type       WeekdayType
  weeknumber Int
  shiftId    Int
  shift      Shift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@map("custom_days")
}

model ContractType {
  id   Int    @id @default(autoincrement())
  name String
  type String

  @@map("contract_types")
}

model WeekDay {
  id        Int     @id @default(autoincrement())
  fullname  String
  isWeekend Boolean @map("is_weekend")
  number    Int     @unique
  shortname String

  @@map("week_days")
}

model EventType {
  id    Int    @id @default(autoincrement())
  name  String @unique
  color String @unique

  @@map("event_types")
}

enum WeekdayType {
  weekend
  workday
}

enum ShiftType {
  custom_days
  cycle
}
