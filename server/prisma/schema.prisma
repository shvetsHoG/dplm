generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  email    String  @unique
  name     String?
  password String

  @@map("users")
}

model Contract {
  id             Int             @id @default(autoincrement())
  name           String
  employeeGroups EmployeeGroup[]
  shift          Shift?

  @@map("contracts")
}

model EmployeeGroup {
  id         Int        @id @default(autoincrement())
  externalId Int        @map("external_id")
  name       String
  employees  Employee[]
  contractId Int        @map("contract_id")
  contract   Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("employee_groups")
}

model Employee {
  id              String        @id @default(cuid())
  fullname        String
  employeeGroupId Int           @map("employee_group_id")
  employeeGroup   EmployeeGroup @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade)
  event           Event[]

  @@map("employees")
}

model Shift {
  id         Int         @id @default(autoincrement())
  duration   Int
  startDate  DateTime    @map("start_date")
  startTime  DateTime    @map("start_time")
  type       ShiftType
  customDays CustomDay[]
  contractId Int         @unique @map("contract_id")
  contract   Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

model Event {
  id          Int       @id @default(autoincrement())
  desc        String
  startDt     DateTime  @map("start_dt")
  endDt       DateTime  @map("end_dt")
  type        EventType @relation(fields: [eventTypeId], references: [id])
  eventTypeId Int       @map("event_type_id")
  employeeId  String    @map("employee_id")
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("events")
}

model CustomDay {
  id         Int         @id @default(autoincrement())
  type       WeekdayType
  weeknumber Int
  shiftId    Int         @map("shift_id")
  shift      Shift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@map("custom_days")
}

model ContractType {
  id   Int    @id @default(autoincrement())
  name String
  type String

  @@map("contract_types")
}

model WeekDay {
  id        Int     @id @default(autoincrement())
  fullname  String
  isWeekend Boolean @map("is_weekend")
  number    Int     @unique
  shortname String

  @@map("week_days")
}

model EventType {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  color String  @unique
  event Event[]

  @@map("event_types")
}

enum WeekdayType {
  weekend
  workday
}

enum ShiftType {
  custom_days
  cycle
}
